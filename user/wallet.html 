<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Fox Store — Mon Portefeuille</title>
    
    <!-- 
        FOX STORE ARCHITECTURE v5.0 - WALLET ENGINE
        GESTION DU SOLDE, HISTORIQUE DES TRANSACTIONS
        ZÉRO SIMULATION - INTÉGRATION FIRESTORE LIVE
    -->

    <!-- Firebase SDK -->
    <script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-firestore-compat.js"></script>
    
    <!-- Font Awesome 6 Pro -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #0056b3;
            --secondary: #001e62;
            --accent: #00d1ff;
            --white: #ffffff;
            --bg-body: #ffffff; 
            --text-main: #0f172a;
            --text-muted: #64748b;
            --success: #10b981;
            --danger: #ef4444;
            --warning: #f59e0b;
            --border: #e2e8f0;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; -webkit-tap-highlight-color: transparent; }
        body { background-color: var(--bg-body); color: var(--text-main); line-height: 1.6; overflow-x: hidden; }

        /* --- HEADER --- */
        header {
            height: 65px; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px);
            display: flex; align-items: center; padding: 0 5%; position: sticky; top: 0; z-index: 1000;
            border-bottom: 1px solid var(--border);
        }
        .back-btn { 
            color: var(--primary); font-size: 1.2rem; text-decoration: none; 
            width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;
            border-radius: 12px; transition: var(--transition);
        }
        header h1 { font-size: 0.95rem; font-weight: 800; color: var(--secondary); text-transform: uppercase; letter-spacing: 0.5px; margin-left: 10px; }

        .container { padding: 25px 5% 100px; max-width: 600px; margin: 0 auto; }

        /* --- BALANCE CARD --- */
        .balance-card {
            background: linear-gradient(135deg, var(--secondary) 0%, var(--primary) 100%);
            border-radius: 28px; padding: 35px 25px; color: white; position: relative;
            overflow: hidden; box-shadow: 0 15px 35px rgba(0, 86, 179, 0.2);
            margin-bottom: 30px;
        }
        .balance-card::after { content: ""; position: absolute; top: -50px; right: -50px; width: 150px; height: 150px; background: rgba(255,255,255,0.05); border-radius: 50%; }
        
        .balance-card span { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; opacity: 0.8; }
        .balance-card h2 { font-size: 2.2rem; font-weight: 800; margin-top: 5px; letter-spacing: -1px; }
        .balance-card .wallet-id { font-size: 0.65rem; font-family: monospace; margin-top: 15px; opacity: 0.6; display: block; }

        /* --- QUICK ACTIONS --- */
        .actions-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 35px; }
        .action-item {
            background: var(--white); border: 1.5px solid var(--border); padding: 18px 10px;
            border-radius: 20px; text-align: center; text-decoration: none; transition: var(--transition);
            display: flex; flex-direction: column; align-items: center; gap: 10px;
        }
        .action-item:hover { border-color: var(--primary); transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,0,0,0.04); }
        .action-item i { width: 42px; height: 42px; background: #f0f7ff; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: var(--primary); font-size: 1.1rem; }
        .action-item span { font-size: 0.75rem; font-weight: 800; color: var(--secondary); }

        /* --- TRANSACTIONS LIST --- */
        .section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
        .section-header h3 { font-size: 0.85rem; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; }
        
        .history-card { background: var(--white); border-radius: 24px; border: 1px solid var(--border); overflow: hidden; }
        
        .transaction-row {
            padding: 18px 20px; border-bottom: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between;
            transition: 0.3s;
        }
        .transaction-row:last-child { border-bottom: none; }
        
        .t-left { display: flex; align-items: center; gap: 15px; }
        .t-icon { width: 40px; height: 40px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 0.9rem; }
        
        .type-depot { background: #e8f5e9; color: var(--success); }
        .type-retrait { background: #fff1f2; color: var(--danger); }
        .type-transfert { background: #f0f7ff; color: var(--primary); }

        .t-info h5 { font-size: 0.85rem; font-weight: 700; color: var(--text-main); }
        .t-info p { font-size: 0.65rem; color: var(--text-muted); font-weight: 600; }

        .t-right { text-align: right; }
        .t-amount { font-weight: 800; font-size: 0.9rem; display: block; }
        .t-status { font-size: 0.6rem; font-weight: 800; text-transform: uppercase; }

        .status-valide { color: var(--success); }
        .status-en-attente { color: var(--warning); }
        .status-rejete { color: var(--danger); }

        /* --- EMPTY STATE --- */
        .empty-state { text-align: center; padding: 40px 20px; color: var(--text-muted); }
        .empty-state i { font-size: 2.5rem; margin-bottom: 15px; opacity: 0.3; }

        @media (max-width: 480px) {
            .balance-card { padding: 30px 20px; }
            .balance-card h2 { font-size: 1.8rem; }
            .action-item span { font-size: 0.65rem; }
        }
    </style>
</head>
<body>

    <header>
        <a href="/home.html" class="back-btn"><i class="fas fa-arrow-left"></i></a>
        <h1>Portefeuille Fox</h1>
    </header>

    <div class="container">
        
        <!-- CARTE DE SOLDE -->
        <div class="balance-card">
            <span>Solde Disponible</span>
            <h2 id="walletBalance">0.00 HTG</h2>
            <span class="wallet-id" id="walletId">ID: Loading...</span>
        </div>

        <!-- ACTIONS RAPIDES -->
        <div class="actions-grid">
            <a href="/user/deposit.html" class="action-item">
                <i class="fas fa-plus-circle"></i>
                <span>Dépôt</span>
            </a>
            <a href="/user/withdraw.html" class="action-item">
                <i class="fas fa-hand-holding-usd"></i>
                <span>Retrait</span>
            </a>
            <a href="/user/transfer.html" class="action-item">
                <i class="fas fa-exchange-alt"></i>
                <span>Transfert</span>
            </a>
        </div>

        <!-- HISTORIQUE DES TRANSACTIONS -->
        <div class="section-header">
            <h3>Historique</h3>
            <i class="fas fa-history" style="color: var(--border); font-size: 0.8rem;"></i>
        </div>

        <div class="history-card" id="transactionList">
            <div style="text-align:center; padding:40px;"><i class="fas fa-spinner fa-spin" style="color:var(--primary)"></i></div>
        </div>

    </div>

    <script>
        /* ==========================================================================
           MOTEUR FINANCIER (ZÉRO SIMULATION)
           ========================================================================== */

        const firebaseConfig = {
            apiKey: "AIzaSyCUhf25OuIvuK-RGg02a1hF_ovN2TI7tDg",
            authDomain: "pay-fusion-6dfaf.firebaseapp.com",
            projectId: "pay-fusion-6dfaf",
            storageBucket: "pay-fusion-6dfaf.firebasestorage.app",
            messagingSenderId: "945593776812",
            appId: "1:945593776812:web:4475e1085fdfa31690fd09",
            measurementId: "G-8FEQG6B7ZY"
        };
        
        firebase.initializeApp(firebaseConfig);
        const db = firebase.firestore();
        const auth = firebase.auth();

        auth.onAuthStateChanged(user => {
            if (user) {
                // 1. SYNC SOLDE UTILISATEUR
                db.collection("users").doc(user.uid).onSnapshot(doc => {
                    if (doc.exists) {
                        const data = doc.data();
                        const balance = data.wallet_balance || 0;
                        document.getElementById('walletBalance').textContent = balance.toLocaleString() + " HTG";
                        document.getElementById('walletId').textContent = "ID COMPTE: " + user.uid.substring(0,12).toUpperCase();

                        // Anti-Ban Security
                        if(data.status === "Banni") window.location.href = "/logout.html";
                    } else {
                        // Initialisation forcée si le champ n'existe pas
                        db.collection("users").doc(user.uid).set({ wallet_balance: 0 }, { merge: true });
                    }
                });

                // 2. SYNC HISTORIQUE TRANSACTIONS
                db.collection("wallet_transactions")
                  .where("userId", "==", user.uid)
                  .orderBy("createdAt", "desc")
                  .onSnapshot(snap => {
                      const container = document.getElementById('transactionList');
                      container.innerHTML = '';

                      if (snap.empty) {
                          container.innerHTML = `<div class="empty-state"><i class="fas fa-folder-open"></i><p style="font-size:0.8rem; font-weight:600;">Aucune transaction enregistrée</p></div>`;
                          return;
                      }

                      snap.forEach(doc => {
                          const t = doc.data();
                          const date = t.createdAt ? new Date(t.createdAt.seconds * 1000).toLocaleDateString('fr-FR', {day:'numeric', month:'short', hour:'2-digit', minute:'2-digit'}) : "En cours...";
                          
                          let icon, typeClass, label, prefix = "";
                          if(t.type === "depot") { icon = "fa-arrow-down"; typeClass = "type-depot"; label = "Dépôt de fonds"; prefix = "+"; }
                          else if(t.type === "retrait") { icon = "fa-arrow-up"; typeClass = "type-retrait"; label = "Retrait de fonds"; prefix = "-"; }
                          else if(t.type === "transfert_envoye") { icon = "fa-paper-plane"; typeClass = "type-transfert"; label = "Vers " + t.recipientEmail; prefix = "-"; }
                          else if(t.type === "transfert_recu") { icon = "fa-hand-holding-usd"; typeClass = "type-depot"; label = "De " + t.senderEmail; prefix = "+"; }
                          else if(t.type === "achat") { icon = "fa-shopping-bag"; typeClass = "type-transfert"; label = "Achat Service"; prefix = "-"; }

                          const statusLabel = t.status === "valide" ? "Validé" : (t.status === "rejete" ? "Rejeté" : "En attente");

                          container.innerHTML += `
                            <div class="transaction-row">
                                <div class="t-left">
                                    <div class="t-icon ${typeClass}"><i class="fas ${icon}"></i></div>
                                    <div class="t-info">
                                        <h5>${label}</h5>
                                        <p>${date}</p>
                                    </div>
                                </div>
                                <div class="t-right">
                                    <span class="t-amount" style="color: ${prefix === '+' ? 'var(--success)' : 'var(--text-main)'}">${prefix}${t.amount.toLocaleString()} HTG</span>
                                    <span class="t-status status-${t.status}">${statusLabel}</span>
                                </div>
                            </div>
                          `;
                      });
                  });

            } else {
                window.location.href = "/login.html";
            }
        });
    </script>
</body>
</html>